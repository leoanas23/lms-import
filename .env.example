# Shared password for the internal team (required)
APP_PASSWORD=change-me

# Anthropic API key for AI-assisted steps (optional - app works without it)
ANTHROPIC_API_KEY=

# Vercel Blob read-write token (auto-set when you add Blob storage in Vercel)
BLOB_READ_WRITE_TOKEN=
# Access mode of the connected Blob store. Default: private (recommended - data has PII).
# Only set to "public" if the store was created with public access.
# BLOB_ACCESS=private

# Google Drive archival (optional). Paste the FULL service account JSON on one line.
GOOGLE_SERVICE_ACCOUNT_JSON=
DRIVE_FOLDER_OUTPUT=
DRIVE_FOLDER_ARCHIVE=
DRIVE_FOLDER_LOGS=
